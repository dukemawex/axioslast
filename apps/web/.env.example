# Public Interswitch merchant code used by inline checkout
NEXT_PUBLIC_INTERSWITCH_MERCHANT_CODE=
# Public Interswitch pay item ID for checkout
NEXT_PUBLIC_INTERSWITCH_PAY_ITEM_ID=
# Checkout mode: TEST for sandbox, LIVE for production
NEXT_PUBLIC_INTERSWITCH_MODE=TEST
# Optional override for checkout script URL (leave empty for mode-based default)
NEXT_PUBLIC_INTERSWITCH_INLINE_SCRIPT_URL=
